# Go API — Secrets (env vars only, not in config.yaml)
ESHOP_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ESHOP_SUPABASE_JWT_SECRET=your-jwt-secret
ESHOP_STRIPE_SECRET_KEY=your-stripe-secret-key
ESHOP_STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Go API — Overrides (defaults in api/config.yaml)
# ESHOP_SERVER_PORT=9090
# ESHOP_SUPABASE_URL=http://127.0.0.1:54321
# ESHOP_SUPABASE_TIMEOUT=10s
# ESHOP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# ESHOP_CORS_MAX_AGE=300
# ESHOP_CHECKOUT_PAYMENT_CURRENCY=usd
# ESHOP_CHECKOUT_WEBHOOK_MAX_BODY_SIZE=65536

# Nuxt Frontend
NUXT_PUBLIC_API_BASE=http://localhost:9090
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key
