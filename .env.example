# Go API — Secrets (env vars only, not in config.yaml)
ESHOP_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ESHOP_SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe — Backend (Go API)
# Secret key from Stripe Dashboard > Developers > API Keys
ESHOP_STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from `stripe listen` CLI output (whsec_...)
ESHOP_STRIPE_WEBHOOK_SECRET=whsec_...

# AI Shopping Assistant
ESHOP_ASSISTANT_ANTHROPIC_API_KEY=your-anthropic-api-key
ESHOP_ASSISTANT_VOYAGE_API_KEY=your-voyage-api-key
# ESHOP_ASSISTANT_MODEL=claude-sonnet-4-5
# ESHOP_ASSISTANT_EMBEDDING_MODEL=voyage-3-large

# Go API — Overrides (defaults in api/config.yaml)
# ESHOP_SERVER_PORT=9090
# ESHOP_SUPABASE_URL=http://127.0.0.1:54321
# ESHOP_SUPABASE_TIMEOUT=10s
# ESHOP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# ESHOP_CORS_MAX_AGE=300
# ESHOP_CHECKOUT_PAYMENT_CURRENCY=usd
# ESHOP_CHECKOUT_WEBHOOK_MAX_BODY_SIZE=65536

# Nuxt Frontend
NUXT_PUBLIC_API_BASE=http://localhost:9090
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key

# Stripe — Frontend (Nuxt)
# Publishable key from Stripe Dashboard > Developers > API Keys
# Must be in frontend/.env (Nuxt reads .env from its own directory)
NUXT_PUBLIC_STRIPE_KEY=pk_test_...
